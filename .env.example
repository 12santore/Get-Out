# App URL (used in auth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenWeather API
OPENWEATHER_API_KEY=your-openweather-key

# Private beta invite codes (comma-separated)
INVITE_CODES=kara-alpha-2026,friend-beta-2026

# Optional fallback coordinates if browser geolocation is unavailable
NEXT_PUBLIC_DEFAULT_LAT=37.7749
NEXT_PUBLIC_DEFAULT_LNG=-122.4194

# Optional admin approval email flow for New City requests (Resend)
RESEND_API_KEY=re_xxx
APPROVAL_EMAIL_FROM=Get Out <onboarding@resend.dev>
APPROVAL_EMAIL_TO=you@example.com

# Google Sheets CSV sync (Apps Script web app)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-deployment-id/exec
GOOGLE_SHEETS_SYNC_SECRET=replace-with-long-random-secret
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheet-id

# Spend safeguards / kill switches
WEATHER_NO_CHARGE_MODE=true
WEATHER_API_ENABLED=true
NEARBY_PULLS_ENABLED=true
NEW_CITY_REQUESTS_ENABLED=true
DAILY_WEATHER_CALL_LIMIT=500
DAILY_NEARBY_PULL_LIMIT=20
DAILY_NEW_CITY_REQUEST_LIMIT=10
MAX_NEARBY_RADIUS_KM=25
MAX_NEARBY_RESULTS_PER_CATEGORY=10

# Optional cost estimates used for spend audit logging
ESTIMATED_WEATHER_CALL_COST_USD=0
ESTIMATED_NEARBY_PULL_COST_USD=0
ESTIMATED_RESEND_EMAIL_COST_USD=0
